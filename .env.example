# Copy this file to .env and fill in your values.
# .env is ignored by git — never commit real secrets.

# JWT — required in production, min 32 characters
APP_JWT_SECRET=change-me-to-a-real-secret-key-of-at-least-32-chars
APP_JWT_EXPIRATION=86400000

# Database (defaults match docker-compose.yml for local dev)
# SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5433/cts_db
# SPRING_DATASOURCE_USERNAME=cts_user
# SPRING_DATASOURCE_PASSWORD=cts_pass

# Upload (defaults work for local dev)
# APP_UPLOAD_DIR=uploads
# APP_UPLOAD_BASE_URL=http://localhost:8080
